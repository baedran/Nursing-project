# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# supabase personal access token (never commit)
.supabase-token
# supabase CLI temp dir
supabase/.temp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
.claude/settings.local.json
.claude/settings.json
.claude/worktrees/

# superpowers brainstorm
/.superpowers/

# playwright MCP screenshot output
/.playwright-mcp/

# local smoke-test scratch
.cookies.tmp.json
.cookies.err
.cookie-set.js
public/__cc_session.json
